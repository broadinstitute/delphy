-  return reinterpret_cast<uintptr_t>(ctrl) >> 12;
+inline size_t PerTableSalt(const ctrl_t* /*ctrl*/) {
+  // DELPHY PATCH: return 0 so that iteration order is fully determined by
+  // the hash values alone.  Delphy needs deterministic runs (same seed =>
+  // same MCMC trajectory), and several hot loops iterate over flat_hash_maps
+  // while consuming RNG draws.  The original code here was:
+  //   return reinterpret_cast<uintptr_t>(ctrl) >> 12;
+  return 0;
 }
 // Extracts the H1 portion of a hash: 57 bits mixed with a per-table salt.
